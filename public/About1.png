"to\":\"До\",\"returns\":\"Порядок и условия возврата товара\",\"publicOffer\":\"Публичная оферта интернет-магазина «GRAND ELECTRA MALL»\",\"best\":\"Лучшие предложения\",\"page\":\"Страница\",\"showMore\":\"Показать ещё\",\"showLess\":\"Показать меньше\",\"search\":\"Поиск\",\"search_text\":\"Простите, по вашему запросу товаров пока нет.\",\"to_main\":\"На главную \",\"save\":\"Сохранить\",\"attribute\":\"Имя атрибута\",\"choise\":\"Имя выбора\",\"pre_order_warn\":\"Для совершения предзаказа вы можете внести предоплату в размере 5 000 000 UZS или оплатить товар полностью\",\"pay_full\":\"Оплатить товар полностью\",\"discount_desc\":\"Ещё нет описание\",\"cashback\":\"Применить бонусные суммы\",\"no_cashback\":\"У вас нет бонусов\",\"review_auth_description\":\"Я подтверждаю, что ознакомлен с общими условиями и соглашаюсь с ними\",\"add_image\":\"Добавить фото\",\"cancel\":\"Oтменить\",\"discount_rules\":\"Правила проведения акции «{{discount}}»\",\"media_club\":\"Правила программы лояльности «MediaClub»\",\"popular_store\":\"Популярные продукты\",\"not_found\":\"Не найдено\",\"max_file_size\":\"Максимальный размер файла {{size}} МБ\",\"hide\":\"Скрыть\",\"choose_region\":\"Выберите город\",\"region_city\":\"г.Ташкент\",\"articles\":\"Cтатьи\",\"user_feedback_success_text\":\"Ваш запрос успешно отправлен. Мы свяжемся с вами как можно скорее.\",\"sale\":\"Скидка\",\"cashback_title\":\"Кэшбэк\",\"menu\":\"Меню\",\"on_whole_pay\":\"Полной оплате\",\"hour\":\"час\",\"minute\":\"минут\",\"second\":\"секунд\",\"day\":\"день\",\"you\":\"Вы\",\"back_to_school\":\"$7:props:resources:ru:common:back_to_school\"},\"header\":{\"ru\":\"Ру\",\"uz\":\"Oʻz\",\"uzb\":\"Oʻzbek\",\"russ\":\"Русский\",\"kir\":\"Ўзбек\",\"lang\":\"Язык\",\"menu\":\"Меню\",\"fortuna\":\"Праздник подарков\",\"aboutus\":\"О нас\",\"mediaclub\":\"MediaClub\",\"trading\":\"Юридическим лицам\",\"delivery\":\"Доставка\",\"branches\":\"Магазины\",\"contacts\":\"Связаться с нами!\",\"catalog\":\"Каталог\",\"search_placeholder\":\"Искать товары\",\"compare\":\"Сравнить\",\"favorite\":\"Избранное\",\"login\":\"Войти\",\"order_status\":\"Статус заказа\",\"basket\":\"Корзина\",\"choose_language\":\"Выберите язык\",\"text\":\"Для проверки статуса заказа введите номер заказа.\",\"cooperation\":\"Партнёрство\",\"yes\":\"Да\",\"choose_your_region\":\"Изменить город\",\"your_city\":\"Ваш город ташкент?\",\"open_in_app\":\"Открыть в приложении\",\"installment\":\"Рассрочка\",\"search_products_title\":\"Популярные товары\",\"search_categories_title\":\"Категории\",\"search_suggestions_title\":\"Подсказки\",\"search_history_title\":\"История поиска\",\"search_taps_title\":\"Часто ищут\",\"sum\":\"сум\"},\"footer\":{\"questions\":\"Возникли вопросы? Готовы помочь:\",\"pay_ways\":\"Способы оплаты\",\"work_time\":\"График работы:\",\"infomation\":\"Информация\",\"garantiya\":\"Гарантия\",\"store_address\":\"Адреса магазинов\",\"all_right_reserved\":\"Все права защищены.\",\"service\":\"Услуги\",\"instalment\":\"Всё о рассрочке\",\"return_goods\":\"Возврат товара\",\"for_buys\":\"Для покупателей\",\"service_center\":\"Сервисный центр\",\"feedback\":\"Оставить отзыв\",\"vacancies\":\"Вакансии\",\"ourstore\":\"Наши магазины\",\"discount\":\"Акция\",\"every_days\":\"Ежедневно\"},\"login\":{\"title\":\"Вход или регистрация\",\"to_code\":\"Получить код\",\"privacy_policy\":\"Принимаю условия\",\"privacy\":\"Политики Конфедициальности\",\"registration\":\"Регистрация\",\"phone\":\"Номер телефона\",\"name\":\"Имя\",\"surname\":\"Фамилия\",\"we_send_messege\":\"Мы отправили код на номер\",\"confirmation_code\":\"Код подтверждения\",\"resend_code\":\"Отправить код повторно\",\"after_seconds\":\"Через {{time}} секунд\",\"error_password\":\"Вы ввели неправильный пароль.\",\"please_try_again\":\"Пожалуйста, попробуйте ещё раз.\",\"privacy_polite\":\"Подтверждаю ознакомление и согласие с условиями\",\"public_ofe\":\"Публичная оферта\",\"confirm_privacy\":\"Примите условия политики\",\"skip\":\"Пропустить\",\"write_code\":\"Введите код\",\"edit\":\"Изменить\",\"write_full_code\":\"Введите полный код!\",\"wrong_code\":\"Код неправильный\",\"again_send\":\"Отправить повторно\",\"placeholder_name\":\"Введите имя\",\"placeholder_surname\":\"Введите фамилию\",\"register\":\"Зарегистрироваться\",\"enter_true_format\":\"Введите правильный номер телефона\",\"enter_full_number\":\"Введите полный номер!\",\"sub_footer_phone\":\"Телефон\",\"signin_google\":\"Войти через Google\",\"connect_phone\":\"Связать номер\",\"connect_account\":\"Связать профиль\",\"sign_in_with_apple\":\"Вход через Apple\",\"or\":\"или\"},\"about\":{\"why_mediapark\":\"Почему именно Mediapark?\",\"hero_title\":\"Мы создаем удобство и комфорт для вас!\",\"hero_text\":\"В 2015 году мы открылись как первая сеть магазинов в Узбекистане, предлагающая cамый широкий ассортимент товаров\",\"years\":\"10 лет\",\"skills\":\"Опыт, на который можно полагаться.\",\"dots\":\"35 точек\",\"stores\":\"торговых точек по всей стране.\",\"we_have\":\"У нас есть товары брендов, которым вы доверяете\",\"all_ploshad\":\"Общая площадь наших магазинов составляет\",\"user_text\":\"Мы предоставляем вам огромный выбор из 21 000 товаров в наших магазинах.\",\"about_how_wewrok\":\"Как мы работаем?\",\"values\":\"Ценности\",\"values_text\":\"Мы заботимся о вашем комфорте в каждой детали. Мы предоставляем широкий выбор товаров для вас и вашей семьи. Мы уделяем особое внимание качеству товаров, чтобы ваша покупка служила вам долго и надёжно. Наши магазины созданы так, чтобы вы чувствовали себя комфортно и уютно во время покупок, а наша команда сотрудников всегда готова помочь вам в этом.\",\"ambition\":\"Амбициозность\",\"ambition_text\":\"Наши сотрудники - это наше богатство. Мы верим, что именно они составляют главную основу успеха нашей компании. Каждый сотрудник Mediapark обладает высоким уровнем профессионализма и страстью к своей работе.Мы работаем в близком сотрудничестве с нашими клиентами, чтобы понять их потребности и предложить товары, которые будут соответствовать их ожиданиям\",\"comfort\":\"Стремление к комфорту\",\"values_card3\":\"Любознательность\",\"values_card_text\":\"Наша любознательность позволяет нам постоянно изучать рынок, анализировать потребности наших клиентов и предлагать продукты, которые наилучшим образом соответствуют их запросам. Благодаря этому мы постоянно растем и расширяемся, предлагая нашим покупателям все только новое и лучшее.\",\"awards\":\"Награды\",\"awards_title1\":\"Премия «BREND 2021»\",\"awards_text1\":\"Победитель номинации Розничная торговля. Магазины бытовой техники\",\"awards_title2\":\"Премия «TAF! 2022»\",\"awards_text2\":\"Победитель номинации “Кампания с использованием национальных ценностей”\",\"awards_text3\":\"Победитель номинации “Интегрированная кампания”\",\"awards_title3\":\"Премия «Brend 2019»\",\"awards_text4\":\"Победитель номинации “Выбор потребителя”\",\"all_awards\":\"Все награды\",\"blocks\":\"$7:props:resources:ru:about:blocks\",\"banner_title\":\"Быстрая и надёжная доставка вместе с Mediapark\",\"ins_company\":\"Мы сотрудничаем с более чем 40 топ-компаниями\",\"aboutus_text\":\"Mediapark - лидер Узбекистана в сфере торговли бытовой техники и электроники. Компания основана в 2015 году как первая сеть магазинов в Узбекистане. Наша компания до сегодняшнего дня поставляла качественную и доступную продукцию миллионам наших соотечественников и продолжает так работать. На сегодняшний день компания имеет 38 филиалов, через которых налажены постоянные оффлайн и онлайн продажи. Девиз нашей компании – надежность, удобство и лидерство. Мы можем стать настоящим партнером для людей в сфере бытовой техники и электроники. Мы предоставляем нашим клиентам и партнерам широкий ассортимент бытовой техники и электроники. В наших магазинах представлено более 21 000 видов товаров производства более 200 брендов. Наша компания стремится поставлять клиентам качественную продукцию и создавать для них комфортные условия наряду с развитием бизнеса.\"},\"sub-footer\":{\"sub_footer_title\":\"Вопросы. Предложения. Жалобы\",\"sub_footer_text\":\"Напишите нам. Мы будем рады получить ваше сообщение.\",\"sub_footer_time\":\"(с 09:00 до 21:00)\",\"sub_footer_day\":\"Пн-Вс: 09:00 - 21:00\",\"sub_footer_office\":\"Офис\",\"location\":\"г. Ташкент, Шайхонтохурский район, ул. Караташ, 11А\",\"form_fullname\":\"Ваше имя\",\"form_message\":\"Сообщение\",\"form_policy\":\"Вы соглашаетесь с\",\"success\":\"Успешный\",\"link_offer\":\"Политикой конфиденциальности\",\"validation\":\"Необходимый\",\"phone_validation\":\"Телефон неверный\"},\"category\":{\"goods\":\"товары\",\"product_discount\":\"Товары со скидкой\",\"manufacturer\":\"Производитель\",\"clear\":\"Очистить\",\"next\":\"Следующий\",\"prev\":\"Предыдущий\",\"sort\":\"Сортировать\",\"new\":\"Новинки\",\"popular\":\"Популярные\",\"ascending_price\":\"Cначала дешевле\",\"descending_price\":\"Сначала дороже\",\"discount\":\"По скидке\",\"subcategroy_faq\":\"Мы отобрали актуальные вопросы\",\"only_store\":\"Только в наличии\",\"price\":\"Цена, Cум\",\"default\":\"По умолчанию\",\"price_asc\":\"Сначала дешевле\",\"price_desc\":\"Сначала дороже\",\"categories\":\"Категории\",\"delete\":\"Удалить\"},\"validations\":{\"select\":\"Выберите вариант\",\"required\":\"Обязательное поле\",\"address_delivery\":\"Адресa доставки\",\"comment_delivery\":\"Комментарий для курьера\",\"orintir\":\"Ориентир\",\"phone_number_length\":\"Номер телефона неполный\",\"choose_from_map\":\"Определите точку получения на карте\",\"terms_and_condition\":\"Вы должны принять условия\",\"choose_delivery\":\"Адрес не выбран\",\"sms_server_unavailable\":\"SMS-сервер временно недоступен\",\"invalid_card\":\"Неверный номер\",\"invalid_expiry\":\"Неверный формат (ММ/ГГ)\",\"invalid_passport\":\"Неверный формат (АА 1234567)\",\"invalid_phone\":\"Неверный формат\",\"invalid_age\":\"Неверный леть\",\"invalid_pinfl\":\"Ошибка ПИНФЛ\",\"min_length_3\":\"Минимум 3 символа\",\"invalid_name_format\":\"Допускаются только